# DeepSeek 官方 API
# 主问答链路固定使用 DeepSeek 官方兼容接口
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow
# Embedding 与 Rerank 都走 SiliconFlow
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=your_siliconflow_api_key

# Kimi Coding API (VLM + LLM)
# 用于图片描述和对话问答
# 关键：必须使用 User-Agent: claude-code 伪装
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_API_KEY=your_kimi_api_key
KIMI_VLM_MODEL=kimi-for-coding
KIMI_CHAT_MODEL=kimi-for-coding
KIMI_VLM_CONCURRENCY=10

# Embedding / Rerank 固定模型
# 这里是硬约束，不能改成其他模型或 4096 维
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSIONS=1536
RERANK_MODEL=Qwen/Qwen3-Reranker-8B

# MinerU 占位配置
MINERU_API_KEY=your_mineru_api_key
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_POLL_INTERVAL=5
MINERU_TIMEOUT=300

# 其他本地基础设施
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=papers
BM25_INDEX_PATH=./data/bm25_index.json
SQLITE_DB_PATH=./data/app.db

# 检索参数
RETRIEVAL_VECTOR_TOP_K=30
RETRIEVAL_BM25_TOP_K=30
RETRIEVAL_FINAL_TOP_K=10
RETRIEVAL_RRF_K=60

# 服务参数
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false
