# ═══════════════════════════════════════════════════════════════════
# 论文助手后端环境变量配置
# ═══════════════════════════════════════════════════════════════════
# 复制为 .env 后按需填写。
# 带 # 注释的为可选配置，有合理默认值。

# ── LLM 配置（必填）─────────────────────────────────────────────
# 支持所有 OpenAI 兼容 API
#
# DeepSeek:   LLM_BASE_URL=https://api.deepseek.com
# 智谱 GLM:   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 硅基流动:   LLM_BASE_URL=https://api.siliconflow.cn/v1
# OpenAI:     LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7
# LLM_TIMEOUT=120
# LLM_FALLBACK_MODELS=            # 逗号分隔的备用模型列表
# LLM_CONTEXT_WINDOW=0            # 0 = 使用系统默认

# ── Reflection 模型（可选，不配则用主 LLM）────────────────────────
# REFLECTION_API_KEY=
# REFLECTION_BASE_URL=
# REFLECTION_MODEL=
# REFLECTION_TEMPERATURE=0.3
# REFLECTION_TIMEOUT=60
# REFLECTION_MAX_ROUNDS=3
# REFLECTION_MAX_DIRECTION_SWITCHES=2

# ── VLM 图片理解（可选）────────────────────────────────────────
# PDF 解析后的图片语义理解
# VLM_API_KEY=
# VLM_BASE_URL=
# VLM_MODEL=
# VLM_TIMEOUT=120
# VLM_MAX_TOKENS=1024
# VLM_MAX_RETRIES=3
# VLM_RETRY_BASE_DELAY_MS=1000
# VLM_RETRY_JITTER_MS=300

# ── MinerU PDF 解析（可选）─────────────────────────────────────
# PDF 精准解析唯一处理器。多 Key 用逗号分隔
# MINERU_API_KEY=sk-aaa,sk-bbb,sk-ccc
# MINERU_BASE_URL=https://mineru.net/api/v4
# MINERU_POLL_INTERVAL=5
# MINERU_TIMEOUT=300
# MINERU_MAX_RETRIES=3
# MINERU_MAX_PAGES_PER_CHUNK=180
# MINERU_MAX_PER_KEY=2            # 单 Key 最大并发

# ── Embedding 配置（必填）──────────────────────────────────────
# base URL 只填到 /v1，客户端自动追加 /embeddings
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIMENSION=1536
# EMBEDDING_TIMEOUT=60
# EMBEDDING_BATCH_SIZE=32
# EMBEDDING_MAX_CONCURRENCY=8
# EMBEDDING_CONTEXT_WINDOW=0

# ── Rerank 配置（预留，暂未启用）─────────────────────────────────
# RERANK_API_KEY=
# RERANK_BASE_URL=
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_TIMEOUT=30

# ── 语义切分参数 ──────────────────────────────────────────────
# 基于 embedding 向量相似度的语义切分，非固定 token 切分
# CHUNK_MIN_TOKENS=128            # 最小 chunk token 数
# CHUNK_MAX_TOKENS=512            # 最大 chunk token 数
# CHUNK_OVERLAP_RATIO=0.10        # chunk 重叠比例
# CHUNK_SIMILARITY_THRESHOLD=0.3  # 语义相似度阈值（低于此值切分）
# CHUNK_EMBEDDING_WINDOW=3        # 滑动窗口大小
# CHUNK_MAX_CONTEXT=32000         # 单 chunk 最大上下文字符数
# CHUNK_TARGET_SIZE=24000         # 目标 chunk 大小
# CHUNK_OVERLAP_BUFFER=8000       # chunk 重叠缓冲区

# ── 检索参数 ──────────────────────────────────────────────────
# RETRIEVAL_TOPK_DENSE=20         # Dense 检索返回数
# RETRIEVAL_TOPK_SPARSE=20        # BM25 稀疏检索返回数
# RETRIEVAL_TOPK_FUSION=10        # RRF 融合后保留数
# RETRIEVAL_TOPK_INITIAL=10       # 最终送入 LLM 的数量
# RETRIEVAL_MAX_DISTANCE=2.0      # 向量距离转分数的最大阈值
# RETRIEVAL_RRF_K=60              # RRF 融合常数 k

# ── 上下文窗口 ────────────────────────────────────────────────
# CONTEXT_WINDOW_TOKENS=32000
# MAX_OUTPUT_TOKENS=4096

# ── 会话压缩 ──────────────────────────────────────────────────
# COMPACT_MAX_SUMMARY_TOKENS=500
# COMPACT_FALLBACK_KEEP_RECENT=6
# COMPACT_TRIGGER_RATIO=0.05

# ── 输入权重 ──────────────────────────────────────────────────
# 三源加权：prompt / selection / written_context
# WEIGHT_PROMPT_THREE_SOURCE=0.5
# WEIGHT_SELECTION_THREE_SOURCE=0.3
# WEIGHT_WRITTEN_THREE_SOURCE=0.2
# 两源加权：selection / written_context
# WEIGHT_SELECTION_TWO_SOURCE=0.7
# WEIGHT_WRITTEN_TWO_SOURCE=0.3

# ── 窗口估算 ──────────────────────────────────────────────────
# AVG_MESSAGE_TOKENS=500
# SYSTEM_PROMPT_TOKENS=2000

# ── UI/输入 ───────────────────────────────────────────────────
# SOURCE_SNIPPET_MAX_LENGTH=220
# TITLE_MAX_LENGTH=20

# ── 软删除 ────────────────────────────────────────────────────
# SOFT_DELETE_RETENTION_DAYS=7

# ── 运行时存储（默认即可）──────────────────────────────────────
# APP_DB_PATH=./data/app.db
# CHROMA_DATA_DIR=./data/chroma_db
# BM25_DATA_DIR=./data/bm25_index
# BACKUP_DIR=./data/backups
# PAPERS_DIR=./data/papers
# PARSED_DIR=./data/parsed
# UPLOADS_DIR=./data/uploads

# ── CORS（默认允许全部来源）────────────────────────────────────
# CORS_ALLOW_ORIGINS=["*"]
