# ============ LLM 配置（必填）============
# 支持所有 OpenAI 兼容的 API，以下为常用示例：
#
# DeepSeek:   LLM_BASE_URL=https://api.deepseek.com      LLM_MODEL=deepseek-chat
# 智谱 GLM:   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4  LLM_MODEL=glm-4-flash
# 硅基流动:   LLM_BASE_URL=https://api.siliconflow.cn/v1  LLM_MODEL=deepseek-ai/DeepSeek-V3
# OpenAI:     LLM_BASE_URL=https://api.openai.com/v1      LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7
# LLM_TIMEOUT=120

# ============ VLM 图片理解（可选）============
# 默认使用 api.coro0.top 代理，复用 My_ProxyAPI_KEY
# 如需独立配置取消注释：
# VLM_API_KEY=
# VLM_BASE_URL=https://api.coro0.top/v1
# VLM_MODEL=qwen3-vl:235b

# ============ MinerU 配置（可选）============
# 用于 PDF 精准解析，无此配置则走轻量文本链
# MINERU_API_KEY=
# MINERU_BASE_URL=https://mineru.net/api/v4

# ============ Embedding 配置（必填）============
# base URL 只填到 /v1，客户端自动追加 /embeddings
# 常用：硅基流动 https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIMENSION=1536
# EMBEDDING_TIMEOUT=60
# EMBEDDING_BATCH_SIZE=32
# EMBEDDING_MAX_CONCURRENCY=8

# ============ Rerank 配置（建议填写）============
# 常用：硅基流动 https://api.siliconflow.cn/v1
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_TIMEOUT=30

# ============ 运行时存储（默认即可）============
# APP_DB_PATH=./data/app.db
# CHROMA_DATA_DIR=./data/chroma_db
# BM25_DATA_DIR=./data/bm25_index
# BACKUP_DIR=./data/backups
# PAPERS_DIR=./data/papers
# PARSED_DIR=./data/parsed
# UPLOADS_DIR=./data/uploads

# ============ Redis（可选；不可用时健康检查会 degraded）============
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_TTL_SECONDS=3600

# ============ 切分参数 ============
# CHUNK_MAX_CONTEXT=32000
# CHUNK_TARGET_SIZE=24000
# CHUNK_OVERLAP_BUFFER=8000

# ============ CORS（默认允许全部来源）============
# CORS_ALLOW_ORIGINS=["*"]
