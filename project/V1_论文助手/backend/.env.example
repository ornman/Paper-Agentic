# === LLM 对话（用户自配，OpenAI 兼容） ===
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=deepseek-chat

# === VLM 图片理解（Kimi） ===
KIMI_API_KEY=sk-kimi-xxx
KIMI_BASE_URL=https://api.kimi.com/coding/v1/messages
KIMI_MODEL=K2.6-code-preview

# === Embedding（硅基流动） ===
SILICONFLOW_API_KEY=sk-xxx
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSIONS=1536

# === PDF 解析 ===
MINERU_API_KEY=xxx

# === 存储 ===
ZVEC_DATA_DIR=./data/zvec_db
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# === 切分策略 ===
CHUNK_MAX_CONTEXT=32000
CHUNK_TARGET_SIZE=24000
CHUNK_OVERLAP_BUFFER=8000
